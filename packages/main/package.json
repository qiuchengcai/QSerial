{
    "name":  "@qserial/main",
    "version":  "1.0.0",
    "description":  "QSerial main process",
    "type":  "module",
    "main":  "./dist/index.js",
    "types":  "./dist/index.d.ts",
    "scripts":  {
                    "dev":  "tsc -p tsconfig.json --watch",
                    "build":  "tsc -p tsconfig.json \u0026\u0026 npm run build:preload",
                    "build:preload":  "esbuild src/preload.ts --bundle --outfile=dist/preload.cjs --format=cjs --platform=node --external:electron",
                    "clean":  "rimraf dist"
                },
    "dependencies":  {
                         "@modelcontextprotocol/sdk":  "^1.29.0",
                         "@qserial/shared":  "workspace:*",
                         "ftp-srv":  "^4.6.3",
                         "node-pty":  "^1.0.0",
                         "serialport":  "^12.0.0",
                         "ssh2":  "^1.15.0",
                         "tftp":  "^0.1.2"
                     },
    "devDependencies":  {
                            "@types/ssh2":  "^1.15.5",
                            "electron":  "^35.7.5",
                            "esbuild":  "^0.20.0",
                            "rimraf":  "^5.0.5",
                            "typescript":  "^5.3.3"
                        },
    "bin":  {
                "qserial-test":  "./dist/cli/index.js"
            }
}
