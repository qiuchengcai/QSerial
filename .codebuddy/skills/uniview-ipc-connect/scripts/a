#!/bin/bash

# 授权码批量生成工具
# 用法: auth-gen.sh <参数>
# 功能: 调用 y 工具生成多组不同配置的授权码

set -e

# 获取脚本所在目录（支持软链接）
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
Y_TOOL="${SCRIPT_DIR}/y"

# 检查 y 工具是否存在
if [[ ! -x "$Y_TOOL" ]]; then
    echo "错误: 找不到 y 工具或无执行权限: $Y_TOOL" >&2
    exit 1
fi

# 检查参数
if [[ -z "$1" ]]; then
    echo "用法: $0 <参数>"
    echo "示例: $0 device_id_123"
    exit 1
fi

PARAM="$1"
DATE=$(date +%Y%m%d)
DEBUG_KEY="Admin123."

# 颜色定义
RED_BG='\e[47;31m'
BLACK_BG='\e[47;30m'
MAGENTA_BG='\e[47;35m'
RESET='\e[0m'

# 辅助函数：生成授权码
generate_code() {
    local bg_color="$1"
    local label="$2"
    shift 2
    echo -en "${bg_color}${label}:${RESET} "
    "$Y_TOOL" "$@"
}

echo "========== 授权码生成 =========="
echo "参数: $PARAM"
echo "日期: $DATE"
echo "================================"
echo ""

# 组合1: 不开调试因子 + 当前日期
generate_code "$RED_BG" "不开调试因子+默认时间" "" "$PARAM" "$DATE"

# 组合2: 打开调试因子 + 当前日期
generate_code "$RED_BG" "打开调试因子+默认时间" "$DEBUG_KEY" "$PARAM" "$DATE"

echo ""

# 组合3: 不开调试因子 + 特定日期
generate_code "$BLACK_BG" "不开调试因子+20111201" "" "$PARAM" "20111201"

# 组合4: 打开调试因子 + 特定日期
generate_code "$BLACK_BG" "打开调试因子+20111201" "$DEBUG_KEY" "$PARAM" "20111201"

echo ""

# 组合5: 不开调试因子 + 纪元日期
generate_code "$MAGENTA_BG" "不开调试因子+19700101" "" "$PARAM" "19700101"

# 组合6: 打开调试因子 + 纪元日期
generate_code "$MAGENTA_BG" "打开调试因子+19700101" "$DEBUG_KEY" "$PARAM" "19700101"

echo ""
echo "========== 生成完成 =========="
